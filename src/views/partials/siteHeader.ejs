<!-- Header (barra superior) -->
<header class="topbar">
  <div class="container topbar__row">
    <a class="brand" href="/" aria-label="Inicio">
      <img src="/img/logo.jpeg" alt="Logo" class="brand__logo" />
    </a>

    <form class="search" action="/productos" method="GET" <%= disableSearchSubmit ? 'onsubmit="return false;"' : '' %>>
      <input
        class="search__input"
        type="search"
        name="q"
        placeholder="Busca tu producto"
        aria-label="Buscar"
        autocomplete="off"
        value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>"
        <%- searchInputId ? `id="${searchInputId}"` : '' %>
      />
      <button class="search__btn" type="submit" aria-label="Buscar">
        <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
          <path d="M10.5 3a7.5 7.5 0 1 0 4.7 13.35l3.23 3.23a1 1 0 0 0 1.42-1.42l-3.23-3.23A7.5 7.5 0 0 0 10.5 3Zm0 2a5.5 5.5 0 1 1 0 11a5.5 5.5 0 0 1 0-11Z"/>
        </svg>
      </button>

      <div class="search__results" id="searchResults"></div>
    </form>

    <div class="actions">
      <!-- Carrito -->
      <button class="cartBtn" id="openCartBtn" type="button" aria-label="Abrir carrito">
        <span class="cartBtn__icon">
          <svg viewBox="0 0 24 24" width="22" height="22" aria-hidden="true">
            <path d="M7 18a2 2 0 1 0 2 2a2 2 0 0 0-2-2Zm10 0a2 2 0 1 0 2 2a2 2 0 0 0-2-2ZM6.2 6l.4 2H19a1 1 0 0 1 1 .8a1 1 0 0 1-.06.56l-1.8 5.4A2 2 0 0 1 16.25 16H8a2 2 0 0 1-1.96-1.61L4.28 4H2a1 1 0 1 1 0-2h3.1a1 1 0 0 1 .98.8L6.2 4H20a1 1 0 0 1 0 2Z"/>
          </svg>
        </span>

        <span class="cartBtn__text">Carrito</span>
        <span class="cartBtn__badge" id="cartBadge" style="display:none;">0</span>
      </button>

      <!-- Mi cuenta (dinámico) -->
      <div class="accountWrap" id="accountWrap">
        <a class="actions__item accountLink" href="/login" aria-label="Mi cuenta" id="accountLink">
          <span class="icon">
            <svg viewBox="0 0 24 24" width="22" height="22" aria-hidden="true">
              <path d="M12 12a4.5 4.5 0 1 0-4.5-4.5A4.5 4.5 0 0 0 12 12Zm0 2c-4.42 0-8 2.24-8 5v1h16v-1c0-2.76-3.58-5-8-5Z"/>
            </svg>
          </span>

          <span class="accountText">
            <small class="accountHello" id="accountHello">Hola</small>
            <span class="accountMain" id="accountText">Inicia sesión</span>
          </span>
        </a>

        <!-- Dropdown (solo visible cuando hay sesión) -->
        <div class="accountMenu" id="accountMenu" style="display:none;">
          <a href="/profile#perfil" class="accountMenu__item">Mi perfil</a>
          <a href="/profile#cuenta" class="accountMenu__item">Datos de la cuenta</a>
          <a href="/profile#seguridad" class="accountMenu__item">Seguridad</a>
          <a href="/profile#favoritos" class="accountMenu__item">Favoritos</a>
          <a href="/profile#compras" class="accountMenu__item">Mis compras</a>
          <div class="accountMenu__sep"></div>
          <button type="button" class="accountMenu__item accountMenu__logout" id="logoutBtn">Cerrar sesión</button>
        </div>
      </div>
    </div>
  </div>
</header>

<!-- Menú principal -->
<nav class="mainnav" aria-label="Navegación principal">
  <div class="container mainnav__row">
    <ul class="mainnav__list">
      <% (topNav || []).forEach(item => { %>
        <li class="mainnav__item">
          <a class="mainnav__link <%= (activePath && item.href === activePath) ? 'is-active' : '' %>" 
             href="<%= item.href %>">
             <%= item.label %>
          </a>
        </li>
      <% }) %>
    </ul>

    <a class="promo" href="#">Promociones</a>
  </div>
</nav>

<script type="module" src="/js/firebase-init.js"></script>
<script type="module" src="/js/header-auth.js"></script>

<script>
  window.__SEARCH_PRODUCTS__ = <%- JSON.stringify(typeof searchProducts !== 'undefined' ? searchProducts : []) %>;
</script>